{
  "name": "ws-doctor",
  "version": "0.1.3",
  "description": "Diagnose WebSocket connection failures across DNS, TLS, HTTP, proxy, and application layers — tells you where your wss:// is dying and why.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "ws-doctor": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json && chmod +x dist/cli.js",
    "dev": "tsx src/cli.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build"
  },
  "keywords": [
    "websocket",
    "diagnostics",
    "debug",
    "socket.io",
    "cloudflare",
    "cli",
    "troubleshooting",
    "ws",
    "wss",
    "doctor"
  ],
  "author": "Tanbir Anjum <tanbiranjum@hotmail.com>",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "undici": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3",
    "vitest": "^2.1.8"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gittanbiranjum/ws-doctor.git"
  },
  "bugs": {
    "url": "https://github.com/gittanbiranjum/ws-doctor/issues"
  },
  "homepage": "https://github.com/gittanbiranjum/ws-doctor"
}
